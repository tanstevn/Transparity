# This is used to remove CLSCompliant issues that flags by Codacy

# Remove the line below if you want to inherit .editorconfig settings from higher directories
root = true

# C# files
[*.cs]

# CA1014 — CLSCompliant (irrelevant for internal backend APIs)
dotnet_diagnostic.CA1014.severity = none

# CA2007 — ConfigureAwait (not needed in ASP.NET Core)
dotnet_diagnostic.CA2007.severity = none

# CA1062 — Validate public method arguments
dotnet_diagnostic.CA1062.severity = none

# CA1303 — Localized string literals
dotnet_diagnostic.CA1303.severity = none

# CA1305 — IFormatProvider
dotnet_diagnostic.CA1305.severity = none

# CS1591 — Missing XML comments
dotnet_diagnostic.CS1591.severity = none

# IDE0058 — Expression value never used
dotnet_diagnostic.IDE0058.severity = none

# IDE0290 — Use primary constructor
dotnet_diagnostic.IDE0290.severity = none
